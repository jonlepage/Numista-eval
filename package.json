{
  "name": "numista-eval",
  "version": "0.1.3",
  "description": "Évaluateur d'échanges Numista — calcule la valeur et l'équité d'un échange entre collectionneurs",
  "type": "module",
  "bin": {
    "numista-eval": "./dist/index.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "evaluate": "tsx src/index.ts doc/echange_etangua_jonlepage_1v2.xls",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "numista",
    "numismatic",
    "coin",
    "exchange",
    "evaluation"
  ],
  "author": "JonLepage",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cfb": "^1.2.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "xlsx-chart": "^0.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
